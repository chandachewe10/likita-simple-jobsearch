# Copy to `.env` and restart the dev server.

EXPO_PUBLIC_OPENAI_API_KEY=sk-your-openai-api-key-here

# SwiftSMS (acceptance notifications)
SWIFTSMS_TOKEN=your-swiftsms-bearer-token
SWIFTSMS_SENDER_ID=FIEROTECHS

# Lenco mobile money collections (employer pays into your Lenco account)
LENCO_API_TOKEN=your-lenco-api-token

# Optional — only needed if you add outbound transfers to workers later
# LENCO_ACCOUNT_ID=your-lenco-account-uuid

# Optional local API overrides (web dev)
# EXPO_PUBLIC_AI_REVIEW_API_URL=http://localhost:3001/api/ai-review
# EXPO_PUBLIC_SMS_API_URL=http://localhost:3001/api/send-sms
# EXPO_PUBLIC_PAYMENT_API_URL=http://localhost:3001/api/lenco-payment
